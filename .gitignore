# Android/Gradle build output
.gradle/
**/build/

# Local environment
local.properties

# IntelliJ/Android Studio
.idea/
*.iml

# Logs and temporary files
*.log
*.tmp
*.swp

# OS files
.DS_Store
Thumbs.db

# Keystore / signing files (never commit secrets)
*.jks
*.keystore
*.p12

# Generated captures and profiling artifacts
captures/
*.hprof

# Kotlin/Java bytecode and packaged artifacts
*.class
*.apk
*.ap_
*.aab

# Keep Gradle wrapper JAR tracked
!gradle/wrapper/gradle-wrapper.jar
