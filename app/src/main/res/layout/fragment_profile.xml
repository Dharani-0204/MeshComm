<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Profile Reminder Banner (for Civilians who skipped) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfileReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFF8E1"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="#FFB300"
            app:strokeWidth="1dp"
            app:contentPadding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete Your Emergency Profile"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your medical information helps rescuers provide better assistance during emergencies."
                    android:textColor="#795548"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="end"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDismissReminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Later"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:textColor="#795548"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCompleteProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete Now"
                        style="@style/Widget.Material3.Button.TonalButton"
                        app:backgroundTint="#FF9800"/>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Identity Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Your Identity"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_onSurface"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleEdit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit"
                        style="@style/Widget.Material3.Button.TextButton"
                        app:icon="@android:drawable/ic_menu_edit"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvUserId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: Loading..."
                    android:textSize="12sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:fontFamily="monospace"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"/>

                <!-- View Mode: Name Display -->
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unknown User"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_theme_onSurface"
                    android:layout_marginBottom="4dp"/>

                <!-- Edit Mode: Name Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your name"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNameEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1"/>

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvUserRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Role: Citizen"
                    android:textSize="14sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:layout_marginBottom="16dp"/>

                <!-- Status Chips Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBattery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/md_theme_onPrimaryContainer"
                        app:chipBackgroundColor="@color/md_theme_primaryContainer"
                        app:chipStrokeWidth="0dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipRelay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Relay: OFF"
                        android:textColor="@color/md_theme_onSecondaryContainer"
                        app:chipBackgroundColor="@color/md_theme_secondaryContainer"
                        app:chipStrokeWidth="0dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipProfileStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile: Incomplete"
                        android:textColor="@android:color/white"
                        app:chipBackgroundColor="#FF9800"
                        app:chipStrokeWidth="0dp"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Medical Profile Card (CIVILIANS ONLY) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMedicalProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/sos_red"
            app:strokeWidth="1dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Emergency Medical Profile"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/sos_red"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:contentDescription="Medical info"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This information is shared with rescuers during emergencies"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"/>

                <!-- Blood Group -->
                <TextView
                    android:id="@+id/tvBloodGroupLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blood Group"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_theme_onSurface"
                    android:layout_marginBottom="4dp"/>

                <!-- View Mode: Blood Group Display -->
                <TextView
                    android:id="@+id/tvBloodGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not specified"
                    android:textSize="16sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:layout_marginBottom="16dp"/>

                <!-- Edit Mode: Blood Group Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilBloodGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select blood group"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <AutoCompleteTextView
                        android:id="@+id/actvBloodGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Medical Conditions -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medical Conditions"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_theme_onSurface"
                    android:layout_marginBottom="4dp"/>

                <!-- View Mode: Conditions Display -->
                <TextView
                    android:id="@+id/tvMedicalConditions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None specified"
                    android:textSize="14sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:layout_marginBottom="16dp"/>

                <!-- Edit Mode: Conditions Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMedicalConditions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g., Diabetes, Heart Disease, Asthma"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:helperText="Separate multiple conditions with commas"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMedicalConditions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="3"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Allergies -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Allergies"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_theme_onSurface"
                    android:layout_marginBottom="4dp"/>

                <!-- View Mode: Allergies Display -->
                <TextView
                    android:id="@+id/tvAllergies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None specified"
                    android:textSize="14sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:layout_marginBottom="8dp"/>

                <!-- Edit Mode: Allergies Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAllergies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g., Penicillin, Peanuts, Latex"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:helperText="Separate multiple allergies with commas"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAllergies"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="3"/>

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mesh Network Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mesh Network Status"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Active Nodes:"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/tvActiveNodes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorPrimary"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Your Role:"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/tvDeviceRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Relay Node"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/mesh_active"/>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Emergency Contacts Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/sos_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/sos_border"
            app:strokeWidth="2dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Emergency Contacts"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/sos_red"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipContactCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="12sp"
                        app:chipBackgroundColor="@color/sos_red"
                        android:textColor="@android:color/white"
                        app:chipMinHeight="24dp"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="These contacts will receive SMS alerts when you send an SOS"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp"/>

                <!-- Contacts List Preview -->
                <LinearLayout
                    android:id="@+id/contactsListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"/>

                <!-- Empty State -->
                <TextView
                    android:id="@+id/tvNoContacts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No emergency contacts selected.\nTap below to add contacts from your phone."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/bg_dashed_border"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickContacts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Select from Phone"
                    app:icon="@android:drawable/ic_menu_add"
                    app:backgroundTint="@color/sos_red"
                    android:textColor="@android:color/white"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Rescuer Dashboard Access Card (RESCUERS ONLY) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRescuerDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#E3F2FD"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="#1976D2"
            app:strokeWidth="1dp"
            app:contentPadding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rescue Operations"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Access the rescue dashboard to view SOS alerts, active devices, and coordinate rescue operations."
                    android:textSize="14sp"
                    android:textColor="#546E7A"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Open Dashboard"
                    app:icon="@android:drawable/ic_menu_mapmode"
                    app:backgroundTint="#1976D2"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button (Edit Mode Only) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Profile"
            android:visibility="gone"
            app:icon="@android:drawable/ic_menu_save"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
