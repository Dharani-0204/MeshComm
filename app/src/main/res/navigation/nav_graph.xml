<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_map">

    <!-- MAP SCREEN - DEFAULT (Most important in disaster) -->
    <fragment
        android:id="@+id/nav_map"
        android:name="com.meshcomm.ui.map.MapFragment"
        android:label="Map">

        <!-- Navigate to SOS screen from Map -->
        <action
            android:id="@+id/action_map_to_sos"
            app:destination="@id/nav_sos"/>
    </fragment>

    <!-- MESH SCREEN - Broadcast communication -->
    <fragment
        android:id="@+id/nav_mesh"
        android:name="com.meshcomm.ui.broadcast.BroadcastFragment"
        android:label="Mesh"/>

    <!-- CHAT LIST SCREEN - 1-to-1 messaging -->
    <fragment
        android:id="@+id/nav_chat"
        android:name="com.meshcomm.ui.chat.ChatFragment"
        android:label="Chat">
        
        <!-- Navigate to specific chat -->
        <action
            android:id="@+id/action_chat_to_chat_detail"
            app:destination="@id/chatDetailFragment"/>
    </fragment>

    <!-- CHAT DETAIL SCREEN - Individual conversation -->
    <fragment
        android:id="@+id/chatDetailFragment"
        android:name="com.meshcomm.ui.chat.ChatDetailFragment"
        android:label="Chat Detail">
        <argument
            android:name="userId"
            app:argType="string"/>
        <argument
            android:name="userName"
            app:argType="string"/>
    </fragment>

    <!-- SOS SCREEN - Emergency -->
    <fragment
        android:id="@+id/nav_sos"
        android:name="com.meshcomm.ui.sos.SOSFragment"
        android:label="SOS">

        <!-- Navigate back to Map with proper back stack preservation -->
        <action
            android:id="@+id/action_sos_to_map"
            app:destination="@id/nav_map"
            app:popUpTo="@id/nav_map"
            app:popUpToInclusive="false"
            app:launchSingleTop="true"/>
    </fragment>

    <!-- PROFILE SCREEN - Settings/Info -->
    <fragment
        android:id="@+id/nav_profile"
        android:name="com.meshcomm.ui.profile.ProfileFragment"
        android:label="Profile"/>

</navigation>
