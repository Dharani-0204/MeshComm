<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Map Status Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/md_theme_primaryContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗺️ Location Map"
                    android:textColor="@color/md_theme_onPrimaryContainer"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvMeshInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="🔴 Mesh offline • Searching for connections..."
                    android:textColor="@color/md_theme_onPrimaryContainer"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvMapInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="No location data received yet"
                    android:textColor="@color/md_theme_onPrimaryContainer"
                    android:textSize="12sp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Emergency Zone Alert -->
        <TextView
            android:id="@+id/tvEmergencyZone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFCDD2"
            android:padding="12dp"
            android:text="⚠️ Emergency zones detected"
            android:textColor="#C62828"
            android:textStyle="bold"
            android:textSize="14sp"
            android:visibility="gone"/>

        <!-- Content Area -->
        <LinearLayout
            android:id="@+id/locationContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Location Overview -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surfaceContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📍 Location Overview"
                            android:textColor="@color/md_theme_onSurface"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEmergencyZones"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Emergency Zones"
                            android:textSize="12sp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="#FF3B30"
                            app:cornerRadius="18dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <TextView
                            android:id="@+id/tvLocationOverview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading location data..."
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/md_theme_onSurface"/>

                    </ScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SOS Alerts Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🚨 SOS Alerts"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF3B30"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to view details"
                    android:textSize="12sp"
                    android:textColor="@color/md_theme_onSurfaceVariant"/>

            </LinearLayout>

            <!-- SOS Alerts List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSosList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="16dp"
                android:clipToPadding="false"/>

        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗺️"
                android:textSize="64sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No location data available"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Messages with GPS enabled will appear here.\nUse the SOS button for emergency alerts with location."
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:textSize="14sp"
                android:gravity="center"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Floating SOS Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/ic_sos"
        app:backgroundTint="#FF3B30"
        app:tint="@android:color/white"
        app:fabSize="normal"
        app:elevation="8dp"
        android:contentDescription="Emergency SOS"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
