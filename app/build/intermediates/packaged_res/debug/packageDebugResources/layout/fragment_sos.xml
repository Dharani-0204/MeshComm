<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface">

    <!-- Emergency Status Bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FF3B30">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 EMERGENCY SOS"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvMeshStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="🔴 Mesh offline • Searching..."
                android:textColor="@android:color/white"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvSosCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 SOS alert(s) received"
                android:textColor="@android:color/white"
                android:textSize="12sp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Emergency Actions Panel -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Main SOS Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="#FF3B30"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/md_theme_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send Emergency Alert"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FF3B30"
                        android:layout_marginBottom="16dp"/>

                    <!-- Voice message input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:hintEnabled="false">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSosMessage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Emergency message (optional)"
                                android:maxLines="3"
                                android:inputType="textMultiLine|textCapSentences"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Voice input button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMic"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="🎤"
                            android:textSize="20sp"
                            style="@style/Widget.Material3.Button.TonalButton"
                            app:cornerRadius="28dp"
                            app:backgroundTint="#FF3B30"/>

                    </LinearLayout>

                    <!-- MAIN SOS BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSOS"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:text="🚨 SEND SOS ALERT"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        app:backgroundTint="#FF3B30"
                        app:cornerRadius="16dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Tap to send SOS\n• Long press for CRITICAL ALERT"
                        android:textSize="12sp"
                        android:textColor="@color/md_theme_onSurfaceVariant"
                        android:gravity="center"/>

                    <!-- Confirmation text -->
                    <TextView
                        android:id="@+id/confirmationText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="✅ SOS SENT!"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"
                        android:gravity="center"
                        android:visibility="gone"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick SOS Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Emergency Alerts"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_onSurface"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Medical Emergency -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickMedical"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="8dp"
                    android:text="🏥 Medical Emergency"
                    android:textSize="16sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#FF3B30"
                    app:cornerRadius="12dp"/>

                <!-- Fire Emergency -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickFire"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="8dp"
                    android:text="🔥 Fire Emergency"
                    android:textSize="16sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#FF3B30"
                    app:cornerRadius="12dp"/>

                <!-- Safety Emergency -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickSafety"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="⚠️ Safety Emergency"
                    android:textSize="16sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="#FF3B30"
                    app:cornerRadius="12dp"/>

            </LinearLayout>

            <!-- Received Alerts Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Received Emergency Alerts"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_onSurface"
                android:layout_marginBottom="8dp"/>

            <!-- Alert list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSosAlerts"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:clipToPadding="false"/>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="48sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No emergency alerts received"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Emergency alerts from the mesh network will appear here"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="14sp"
                    android:gravity="center"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>